{
  "name": "agentim",
  "version": "0.1.0",
  "description": "Gateway CLI for connecting AI coding agents to AgentIM",
  "license": "AGPL-3.0-only",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/NoPKT/AgentIM.git",
    "directory": "packages/gateway"
  },
  "homepage": "https://github.com/NoPKT/AgentIM#connecting-ai-agents",
  "author": "NoPKT LLC",
  "engines": {
    "node": ">=24"
  },
  "keywords": [
    "agentim",
    "gateway",
    "ai",
    "agent",
    "claude-code",
    "codex",
    "gemini",
    "cli"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "bin": {
    "agentim": "dist/cli.js",
    "aim": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/cli.ts",
    "start": "node dist/cli.js",
    "test": "node --import tsx --test test/*.test.ts",
    "clean": "rm -rf dist .turbo",
    "lint": "eslint src/ && tsc --noEmit"
  },
  "dependencies": {
    "@agentim/shared": "workspace:*",
    "@anthropic-ai/claude-agent-sdk": "^0.2.70",
    "@google/gemini-cli-core": "^0.31.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@openai/codex-sdk": "^0.107.0",
    "commander": "^14.0.3",
    "ink": "^6.8.0",
    "ink-select-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "nanoid": "^5.1.0",
    "react": "^19.2.4",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/ws": "^8.5.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.2"
  }
}
